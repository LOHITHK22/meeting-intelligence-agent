# Copy this to .env and fill in your values

# Required for speaker diarization (pyannote.audio)
# Get a free token at https://hf.co/settings/tokens
# Then accept the model terms at https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# Optional: "tiny" | "base" | "small" | "medium" | "large"
# base = good for demos (~74MB), large = production quality (~1.5GB)
WHISPER_MODEL=base

# Optional: Use OpenAI API for Whisper instead of local model
# OPENAI_API_KEY=sk-...
